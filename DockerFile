FROM python:3.12-slim

RUN useradd --create-home --uid 1000 cyberwatch
WORKDIR /app

COPY pyproject.toml README.md ./
COPY src ./src

RUN pip install --no-cache-dir .

RUN mkdir -p /app/data /app/config && chown -R cyberwatch:cyberwatch /app
USER cyberwatch

ENTRYPOINT ["python", "-m", "cyberwatch"]
CMD ["run"]